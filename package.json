{
  "name": "gms-inventory-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "source .env.local && ./scripts/db-seed.sh",
    "db:console": "source .env.local && ./scripts/db-console.sh",
    "db:query": "source .env.local && ./scripts/db-query.sh",
    "db:verify": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/test-api-endpoints.js",
    "db:check-migrations": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/check-migrations.js",
    "db:check-all": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/comprehensive-data-check.js",
    "ghost:verify": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/verify-loaded-data.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-table": "^8.11.6",
    "next": "14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.10.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pg": "^8.17.2",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
