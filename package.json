{
  "name": "gms-inventory-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "source .env.local && ./scripts/db-seed.sh",
    "db:console": "source .env.local && ./scripts/db-console.sh",
    "db:query": "source .env.local && ./scripts/db-query.sh",
    "db:verify": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/test-api-endpoints.js",
    "db:check-migrations": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/check-migrations.js",
    "db:check-all": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/comprehensive-data-check.js",
    "ghost:verify": "export $(cat .env.local | grep -v '^#' | xargs) && node scripts/verify-loaded-data.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-table": "^8.11.6",
    "canvas": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "next": "14.2.35",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.10.4",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pg": "^8.17.2",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
